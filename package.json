{
  "name": "legal-docs-mcp",
  "version": "2.0.5",
  "description": "MCP server for generating legal documents — CGV, CGU, NDA, privacy policies, freelance contracts, and more. For freelancers, startups, and SMBs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "legal-docs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "legal",
    "documents",
    "cgv",
    "cgu",
    "nda",
    "privacy-policy",
    "gdpr",
    "freelance",
    "contract",
    "french-law",
    "mentions-legales",
    "devis"
  ],
  "author": "MCP Tools Lab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tools-lab/legal-docs-mcp.git"
  },
  "homepage": "https://github.com/mcp-tools-lab/legal-docs-mcp",
  "bugs": "https://github.com/mcp-tools-lab/legal-docs-mcp/issues",
  "mcpName": "io.github.mcp-tools-lab/legal-docs-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "LICENSE",
    "TERMS.md",
    "PRIVACY.md",
    "server.json"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/sceneview"
    },
    {
      "type": "polar",
      "url": "https://polar.sh/sceneview"
    }
  ]
}
